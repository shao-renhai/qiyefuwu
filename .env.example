# 云上融环境变量样例。
# 实际使用:复制为 .env 并填入真实值。.env 已在 .gitignore 中,不会被提交。
# 如果使用 systemd / docker / pm2,把这些变量写进对应的环境配置。

# ---------------------------------------------------------------------------
# JWT 签名密钥(必填,生产环境)
# ---------------------------------------------------------------------------
# 不设置时:开发模式下后端会自动生成随机临时 key 并打印警告;
#          生产环境登录态会因进程重启失效,**必须设置**。
# 生成方式:python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# ---------------------------------------------------------------------------
# 数据库连接(可选,默认本地 SQLite)
# ---------------------------------------------------------------------------
# 默认值:sqlite:///backend/data/finance.db
# 切换 PostgreSQL:postgresql+psycopg://user:pass@host:5432/dbname
# DATABASE_URL=
